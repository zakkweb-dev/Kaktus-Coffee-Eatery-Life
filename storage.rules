rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // 1. All visitors can view images
      allow read: if true;

      // 2. Only authenticated administrators can upload, edit, or delete images
      allow write: if request.auth != null && (
        request.auth.token.email == 'alrazakiswar11@gmail.com' ||
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
      );
    }
  }
}
