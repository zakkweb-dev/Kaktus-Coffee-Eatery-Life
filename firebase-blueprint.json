{
  "entities": {
    "Produk": {
      "title": "Produk",
      "description": "Daftar produk menu Kaktus Coffee Eatery Life",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "harga": { "type": "number" },
        "kategori": { "type": "string" },
        "fotoUrl": { "type": "string" },
        "deskripsi": { "type": "string" },
        "isBestSeller": { "type": "boolean" }
      },
      "required": ["id", "nama", "harga", "kategori", "fotoUrl"]
    },
    "Launching": {
      "title": "Launching",
      "description": "Menu launching baru atau promo khusus",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "hargaNormal": { "type": "number" },
        "hargaPromo": { "type": "number" },
        "tanggalMulai": { "type": "string" },
        "tanggalSelesai": { "type": "string" },
        "badge": { "type": "string" },
        "fotoUrl": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "nama", "hargaNormal", "hargaPromo", "fotoUrl"]
    },
    "Event": {
      "title": "Event",
      "description": "Event terjadwal di cafe",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "tanggal": { "type": "string" },
        "fotoUrl": { "type": "string" },
        "deskripsi": { "type": "string" }
      },
      "required": ["id", "nama", "tanggal", "fotoUrl"]
    },
    "Galeri": {
      "title": "Galeri",
      "description": "Foto galeri kafe",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fotoUrl": { "type": "string" },
        "deskripsi": { "type": "string" }
      },
      "required": ["id", "fotoUrl"]
    },
    "Cabang": {
      "title": "Cabang",
      "description": "Cabang outlet kafe",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "alamat": { "type": "string" },
        "jamOperasional": { "type": "string" },
        "mapsUrl": { "type": "string" },
        "noWa": { "type": "string" },
        "fotoUrl": { "type": "string" },
        "linkGrabFood": { "type": "string" },
        "noWaCake": { "type": "string" },
        "pesanWaCake": { "type": "string" }
      },
      "required": ["id", "nama", "alamat", "mapsUrl", "noWa", "fotoUrl"]
    },
    "CustomCake": {
      "title": "CustomCake",
      "description": "Koleksi model kue kustomisasi premium",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "deskripsi": { "type": "string" },
        "hargaMulai": { "type": "number" },
        "fotoUrl": { "type": "string" },
        "pilihanRasa": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "nama", "deskripsi", "hargaMulai", "fotoUrl"]
    },
    "DatabaseConfig": {
      "title": "DatabaseConfig",
      "description": "Pengaturan database dan link GrabFood",
      "type": "object",
      "properties": {
        "linkGrabFood": { "type": "string" },
        "noWaCake": { "type": "string" },
        "logoUrl": { "type": "string" }
      },
      "required": ["linkGrabFood"]
    },
    "Admins": {
      "title": "Admins",
      "description": "Daftar administrator dengan role Owner atau Manager",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Owner", "Manager"] }
      },
      "required": ["uid", "email", "role"]
    },
    "HeroBanner": {
      "title": "HeroBanner",
      "description": "Metadata banner hero interaktif",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fotoUrl": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "isActive": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["id", "fotoUrl", "isActive", "order"]
    },
    "Review": {
      "title": "Review",
      "description": "Ulasan customer real-time",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "rating": { "type": "number" },
        "ulasan": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "nama", "rating", "ulasan", "status", "createdAt"]
    }
  },
  "firestore": {
    "produk": {
      "schema": "Produk",
      "description": "Koleksi produk"
    },
    "launching": {
      "schema": "Launching",
      "description": "Koleksi item launching baru"
    },
    "event": {
      "schema": "Event",
      "description": "Koleksi event terjadwal"
    },
    "galeri": {
      "schema": "Galeri",
      "description": "Koleksi galeri foto aktivitas"
    },
    "cabang": {
      "schema": "Cabang",
      "description": "Koleksi cabang outlet"
    },
    "custom_cake": {
      "schema": "CustomCake",
      "description": "Koleksi model kue kustomisasi premium"
    },
    "config": {
      "schema": "DatabaseConfig",
      "description": "Pengaturan database"
    },
    "admins": {
      "schema": "Admins",
      "description": "Daftar administrator"
    },
    "hero_banners": {
      "schema": "HeroBanner",
      "description": "Pengaturan banner slider utama"
    },
    "reviews": {
      "schema": "Review",
      "description": "Ulasan customer real-time"
    }
  }
}
